{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Narrator",
  "version": "0.5.2",
  "identifier": "com.narrator.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Narrator",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost blob: data:; media-src 'self' asset: http://asset.localhost blob: data: stream:; connect-src 'self' ipc: http://ipc.localhost https://api.anthropic.com https://api.openai.com https://api.elevenlabs.io https://eu.aptabase.com; frame-ancestors 'none'; base-uri 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$HOME/.narrator/**", "$DOCUMENT/**", "$DESKTOP/**", "$DOWNLOAD/**", "$VIDEO/**", "$TEMP/**", "/tmp/**"],
          "deny": ["$HOME/.narrator/config.json"]
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/roalexandru/VideoNarrator/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkzMzU1QjI0MjkyRkI3NUMKUldSY3R5OHBKRnMxa3lMQjlYbzkvU1ZFOSs3dzEwbUpaOWxpRVJJNk1WbC9jWjNLeVEzWXRVMWsK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "resources": [
      "styles/*.toml"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
